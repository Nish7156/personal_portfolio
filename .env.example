# !STARTERCONF Duplicate this to .env.local

# DEVELOPMENT TOOLS
# Ideally, don't add them to production deployment envs
# !STARTERCONF Change to true if you want to log data
NEXT_PUBLIC_SHOW_LOGGER="false"

# SITE URL
# Absolute base URL used for metadataBase, OG/Twitter images and the sitemap.
# Defaults to the Vercel URL. Set this once a custom domain is pointed at the site.
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"